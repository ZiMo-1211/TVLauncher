<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <TextView
        android:id="@+id/tv_datetime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:layout_marginStart="40dp"
        android:text="8:08 AM Saturday, November 11"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/grid_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:clipToPadding="false"
        android:padding="8dp"
        android:focusable="true"
        android:focusableInTouchMode="true" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="40dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:focusable="false">

        <TextView
            android:id="@+id/btn_keystone"
            android:layout_width="140dp"
            android:layout_height="60dp"
            android:text="@string/keystone"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:drawableTop="@drawable/ic_keystone"
            android:drawablePadding="4dp"
            android:background="@drawable/bg_button"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_marginEnd="16dp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/btn_miracast"
            android:layout_width="140dp"
            android:layout_height="60dp"
            android:text="@string/miracast"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:drawableTop="@drawable/ic_miracast"
            android:drawablePadding="4dp"
            android:background="@drawable/bg_button"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_marginEnd="16dp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/btn_signal_source"
            android:layout_width="140dp"
            android:layout_height="60dp"
            android:text="@string/signal_source"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:drawableTop="@drawable/ic_signal_source"
            android:drawablePadding="4dp"
            android:background="@drawable/bg_button"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_marginEnd="16dp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/btn_my_apps"
            android:layout_width="140dp"
            android:layout_height="60dp"
            android:text="@string/my_apps"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:drawableTop="@drawable/ic_my_apps"
            android:drawablePadding="4dp"
            android:background="@drawable/bg_button"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_marginEnd="16dp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/btn_settings"
            android:layout_width="140dp"
            android:layout_height="60dp"
            android:text="@string/settings"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:drawableTop="@drawable/ic_settings"
            android:drawablePadding="4dp"
            android:background="@drawable/bg_button"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

</RelativeLayout>
